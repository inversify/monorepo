{
  "author": "Roberto Pintos López",
  "bugs": {
    "url": "https://github.com/inversify/monorepo/issues"
  },
  "description": "Inversify changesets changelog generator",
  "devDependencies": {
    "@inversifyjs/eslint-plugin-require-extensions": "workspace:*",
    "@changesets/types": "6.1.0",
    "eslint": "10.2.0",
    "prettier": "3.8.2",
    "rimraf": "6.1.3",
    "tslib": "2.8.1",
    "typescript": "6.0.2"
  },
  "homepage": "https://inversify.io",
  "keywords": [],
  "devEngines": {
    "pnpm": "^10.13.1"
  },
  "license": "MIT",
  "exports": {
    ".": "./lib/index.js"
  },
  "name": "@inversifyjs/foundation-changelog-generator",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inversify/monorepo.git"
  },
  "scripts": {
    "build": "tsc",
    "build:clean": "rimraf lib",
    "format": "prettier --write ./src",
    "lint": "eslint ./src",
    "prebuild": "pnpm run build:clean"
  },
  "version": "0.2.0",
  "type": "module"
}
