  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/types": "3.10.1",
    "@eslint/js": "10.0.1",
    "@types/react": "19.2.17",
    "eslint": "10.6.0",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "prettier": "3.9.5",
