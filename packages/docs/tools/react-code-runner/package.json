    "@rollup/plugin-terser": "1.0.0",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/babel__core": "7.20.5",
    "@types/babel__standalone": "7.1.9",
    "@types/react": "19.2.14",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "10.3.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "glob": "13.0.6",
    "inversify": "8.1.0",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "rollup": "4.60.3",
    "ts-loader": "9.5.7",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "unplugin-dts": "1.0.0",
    "vite": "8.0.12",
    "vite-plugin-lib-inject-css": "2.2.2"
  },
  "peerDependencies": {
    "@babel/standalone": "^7.29.4",
    "@swc/wasm-web": "^1.15.33",
    "monaco-editor": "~0.55.1",
    "react": "19.2.6"
  },
  "homepage": "https://inversify.io",
  "devEngines": {
    "node": "^24.10.0",
    "pnpm": "^10.13.1"
  },
  "license": "MIT",
  "exports": {
    ".": "./lib/esm/index.js",
    "./InversifyCodeEditor": "./lib/esm/components/InversifyCodeEditor/index.js",
    "./inversifyBundle.js": "./lib/esm/inversifyBundle.js",
    "./generated/types.d.ts.txt": "./generated/types.d.ts.txt"
  },
  "name": "@inversifyjs/react-code-runner",
  "private": true,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inversify/monorepo.git"
  },
  "scripts": {
    "build": "pnpm run build:esm",
    "build:esm": "rollup -c ./bundle.rollup.config.mjs && pnpm run bundle:types:esm && vite build",
    "build:clean": "rimraf generated lib",
    "bundle:types:esm": "pnpm exec api-extractor run --local --verbose",
    "format": "prettier --write ./src",
    "lint": "eslint ./src",
    "prebuild": "pnpm run build:clean"
  },
  "type": "module"
}
