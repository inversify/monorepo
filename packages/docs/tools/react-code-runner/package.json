  "description": "InversifyJS bundles package",
  "devDependencies": {
    "@babel/types": "7.29.0",
    "@eslint/config-helpers": "0.6.0",
    "@eslint/js": "10.0.1",
    "@inversifyjs/common": "workspace:*",
    "@inversifyjs/container": "workspace:*",
