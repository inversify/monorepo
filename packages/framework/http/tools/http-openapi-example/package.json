{
  "author": "Roberto Pintos López",
  "bugs": {
    "url": "https://github.com/inversify/monorepo/issues"
  },
  "description": "InversifyJs HTTP OpenAPI example package",
  "dependencies": {
    "@inversifyjs/http-core": "workspace:*",
    "@inversifyjs/http-express": "workspace:*",
    "@inversifyjs/http-open-api": "workspace:*",
    "express": "^5.2.1",
    "inversify": "^8.1.0",
    "lmdb": "^3.5.4"
  },
  "devDependencies": {
    "@inversifyjs/eslint-plugin-require-extensions": "workspace:*",
    "@inversifyjs/open-api-types": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/node": "24.12.3",
    "eslint": "10.3.0",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "typescript": "6.0.3"
  },
  "devEngines": {
    "node": "^24.10.0",
    "pnpm": "^10.13.1"
  },
  "homepage": "https://inversify.io",
  "keywords": [
    "dependency injection",
    "dependency inversion",
    "di",
    "inversion of control container",
    "ioc",
    "javascript",
    "node",
    "typescript"
  ],
  "license": "MIT",
  "exports": {
    ".": "./lib/index.js"
  },
  "name": "@inversifyjs/http-openapi-example",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inversify/monorepo.git"
  },
  "scripts": {
    "build": "tsc",
    "build:clean": "rimraf lib",
    "format": "prettier --write ./src/**/*.ts",
    "lint": "eslint ./src",
    "prebuild": "pnpm run build:clean",
    "serve": "node ./lib/index.js"
  },
  "type": "module",
  "version": "1.0.0"
}
