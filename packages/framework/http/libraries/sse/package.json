{
  "author": "Roberto Pintos López",
  "bugs": {
    "url": "https://github.com/inversify/monorepo/issues"
  },
  "description": "InversifyJs http sse package",
  "dependencies": {
    "@inversifyjs/framework-core": "workspace:*",
    "@inversifyjs/http-core": "workspace:*"
  },
  "devDependencies": {
    "@hono/node-server": "2.0.1",
    "@inversifyjs/eslint-plugin-require-extensions": "workspace:*",
    "@inversifyjs/http-express": "workspace:*",
    "@inversifyjs/http-express-v4": "workspace:*",
    "@inversifyjs/http-fastify": "workspace:*",
    "@inversifyjs/http-hono": "workspace:*",
    "@inversifyjs/http-uwebsockets": "workspace:*",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/typescript-checker": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@types/express": "5.0.6",
    "@types/express4": "npm:@types/express@4.17.25",
    "@types/node": "24.12.2",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.3.0",
    "express": "5.2.1",
    "express4": "npm:express@4.22.1",
    "fastify": "5.8.5",
    "hono": "4.12.16",
    "inversify": "8.1.0",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.66.0",
    "vitest": "4.1.5"
  },
  "devEngines": {
    "node": "^24.10.0",
    "pnpm": "^10.13.1"
  },
  "homepage": "https://inversify.io",
  "keywords": [
    "inversify",
    "framework",
    "http",
    "node",
    "sse",
    "typescript"
  ],
  "license": "MIT",
  "exports": {
    ".": "./lib/index.js"
  },
  "name": "@inversifyjs/http-sse",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inversify/monorepo.git"
  },
  "scripts": {
    "build": "tsc",
    "build:clean": "rimraf lib",
    "format": "prettier --write ./src",
    "lint": "eslint ./src",
    "prebuild": "pnpm run build:clean",
    "test": "vitest run",
    "test:integration": "pnpm run test --project Integration",
    "test:coverage": "pnpm run test:unit --coverage",
    "test:mutation": "stryker run",
    "test:uncommitted": "pnpm run test --changed=HEAD",
    "test:unit": "pnpm run test --project Unit"
  },
  "version": "2.0.10",
  "type": "module"
}
