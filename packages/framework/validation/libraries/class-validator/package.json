{
  "author": "Roberto Pintos López",
  "bugs": {
    "url": "https://github.com/inversify/monorepo/issues"
  },
  "description": "InversifyJs class-validator validation package",
  "dependencies": {
    "@inversifyjs/reflect-metadata-utils": "1.5.0",
    "@inversifyjs/validation-common": "workspace:*"
  },
  "devDependencies": {
    "@inversifyjs/eslint-plugin-require-extensions": "workspace:*",
    "@inversifyjs/framework-core": "workspace:*",
    "@inversifyjs/http-core": "workspace:*",
    "@inversifyjs/http-express": "workspace:*",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/typescript-checker": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@types/express": "5.0.6",
    "@types/node": "24.12.2",
    "@vitest/coverage-v8": "4.1.4",
    "eslint": "10.2.0",
    "inversify": "8.1.0",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "tslib": "2.8.1",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  },
  "devEngines": {
    "node": "^24.10.0",
    "pnpm": "^9.12.1"
  },
  "homepage": "https://inversify.io",
  "keywords": [
    "dependency injection",
    "dependency inversion",
    "di",
    "inversion of control container",
    "ioc",
    "javascript",
    "node",
    "typescript"
  ],
  "license": "MIT",
  "exports": {
    ".": "./lib/index.js"
  },
  "name": "@inversifyjs/class-validation",
  "peerDependencies": {
    "class-transformer": "~0.5.1",
    "class-validator": "~0.15.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inversify/monorepo.git"
  },
  "scripts": {
    "build": "tsc",
    "build:clean": "rimraf lib",
    "format": "prettier --write ./src",
    "lint": "eslint ./src",
    "prebuild": "pnpm run build:clean",
    "test": "vitest run",
    "test:integration": "pnpm run test --project Integration",
    "test:coverage": "pnpm run test:unit --coverage",
    "test:mutation": "stryker run",
    "test:uncommitted": "pnpm run test --changed=HEAD",
    "test:unit": "pnpm run test --project Unit"
  },
  "version": "3.1.0",
  "type": "module"
}
